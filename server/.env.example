# Auth server
AUTH_SERVER_PORT=4000
NODE_ENV=production

# Use strong random values in production
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# CORS and frontend URL
FRONTEND_URL=https://enmnvv2006.github.io/FruitMarket/
CORS_ORIGINS=https://enmnvv2006.github.io,http://localhost:3000

# Cookie settings for cross-domain frontend/backend
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=your-backend-domain.com
